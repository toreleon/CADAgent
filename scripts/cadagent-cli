#!/usr/bin/env bash
# CAD Agent CLI — single-shot trajectory runner.
#
# Usage:   scripts/cadagent-cli "your prompt here"
#
# Forces bypassPermissions so tools run without approval prompts, auto-skips
# any AskUserQuestion, and streams everything to stdout. Intended for quick
# trajectory tracing during development.

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ $# -eq 0 ]]; then
    echo "usage: $(basename "$0") \"<prompt>\"" >&2
    exit 2
fi

FC_HOME="${CADAGENT_FC_HOME:-$HERE/.fc-home}"
mkdir -p "$FC_HOME/.local/share" "$FC_HOME/.config"

FC_BIN="$HERE/build/debug/bin/FreeCADCmd"
if [[ ! -x "$FC_BIN" ]]; then
    echo "FreeCADCmd not found at $FC_BIN — run 'pixi run build-debug' first." >&2
    exit 1
fi

MOD_DIR="$HERE/build/debug/Mod/CADAgent"
if [[ ! -d "$MOD_DIR" ]]; then
    MOD_DIR="$HERE/src/Mod/CADAgent"
fi

# Pass the concatenated prompt as a single argv[1] to the embedded script.
# Python's sys.argv inside FreeCADCmd -c is typically ['FreeCADCmd', ...extra].
# Easiest reliable path: stash it in an env var and read it in Python.
export CADAGENT_CLI_PROMPT="$*"

exec env \
    HOME="$FC_HOME" \
    XDG_DATA_HOME="$FC_HOME/.local/share" \
    XDG_CONFIG_HOME="$FC_HOME/.config" \
    CADAGENT_DEBUG="${CADAGENT_DEBUG:-}" \
    CADAGENT_CLI_PROMPT="$CADAGENT_CLI_PROMPT" \
    "$FC_BIN" -c "
import os, sys
sys.path.insert(0, '$MOD_DIR')
from cli import main
raise SystemExit(main(os.environ.get('CADAGENT_CLI_PROMPT', '')))
"
